{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Submit to Codeforces + GitHub",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}\\submit.ps1",
        "-File", "${file}",
        "-Problem", "${input:problemId}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test with Sample Cases",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}\\test.ps1",
        "-File", "${file}",
        "-Problem", "${input:problemId}"
      ],
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "type": "promptString",
      "id": "problemId",
      "description": "Problem ID (e.g. 4A for Codeforces Round 4 problem A)",
      "default": ""
    }
  ]
}
