{
  "manifest_version": 3,
  "name": "CF × GitHub Sync",
  "version": "1.0.0",
  "description": "Automatically sync your Codeforces AC solutions to GitHub",
  "author": "Hasan",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CF × GitHub Sync"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.codeforces.com/*"],
      "js": ["content/codeforces.js"],
      "css": ["content/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "*://*.codeforces.com/*",
    "https://api.github.com/*"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content/badge.css"],
      "matches": ["*://*.codeforces.com/*"]
    }
  ]
}
